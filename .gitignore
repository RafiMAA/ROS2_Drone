# ─────────────────────────────────────────────────────────
#  ROS2 Drone GCS — .gitignore
# ─────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════
#  ROS 2 / Colcon Build Artifacts
# ══════════════════════════════════════════════════════════
build/
install/
log/

# ══════════════════════════════════════════════════════════
#  ArduPilot (cloned as source — large repo, use submodule)
# ══════════════════════════════════════════════════════════
src/ardupilot/

# ══════════════════════════════════════════════════════════
#  ArduPilot SITL Runtime Artifacts
# ══════════════════════════════════════════════════════════
eeprom.bin
mav.tlog
mav.tlog.raw
mav.parm
mav_*.parm
*.stlog

# ══════════════════════════════════════════════════════════
#  Large Binaries / Applications
# ══════════════════════════════════════════════════════════
*.AppImage
*.deb
*.snap

# ══════════════════════════════════════════════════════════
#  Node.js / React / Vite (drone_gcs frontend)
# ══════════════════════════════════════════════════════════
node_modules/
dist/
*.tsbuildinfo
.vite/

# ══════════════════════════════════════════════════════════
#  Python
# ══════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt
.venv/
venv/

# ══════════════════════════════════════════════════════════
#  Gazebo / Simulation Artifacts
# ══════════════════════════════════════════════════════════
gazebo_terrain/terrain_pit_model.zip
src/ardupilot_gazebo/build/

# ══════════════════════════════════════════════════════════
#  IDE & Editor Files
# ══════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
.project
.cproject
.settings/

# ══════════════════════════════════════════════════════════
#  OS Generated Files
# ══════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
desktop.ini

# ══════════════════════════════════════════════════════════
#  Test & Debug Artifacts
# ══════════════════════════════════════════════════════════
crops/
test_*.py
test_*.js

# ══════════════════════════════════════════════════════════
#  Temporary Analysis Scripts (root-level helpers)
# ══════════════════════════════════════════════════════════
analyze_*.py
check_*.py
save_img.py

# ══════════════════════════════════════════════════════════
#  Miscellaneous
# ══════════════════════════════════════════════════════════
*.log
core
core.*
